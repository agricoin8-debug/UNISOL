run = "bash start.sh"
entrypoint = "start.sh"

[nix]
channel = "stable-23_11"

[env]
DATABASE_URL = "postgresql://sniper:sniperpass@localhost:5432/sniperdb"
DRY_RUN = "true"
NODE_ENV = "development"
VITE_BACKEND_URL = "https://$REPL_SLUG.$REPL_OWNER.repl.co"
PORT = "4000"

[deployment]
run = ["sh", "-c", "bash start.sh"]

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 4000
externalPort = 4000
